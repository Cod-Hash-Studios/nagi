---
import MarketingLayout from '../components/MarketingLayout.astro';
---

<MarketingLayout
  title="Nagi plugins"
  description="The Nagi plugin registry is being rebuilt under the Nagi trust model."
  canonicalPath="/plugins/"
>
  <main class="plugins-page">
    <section class="section plugins-hero">
      <p class="section-kicker"># plugins</p>
      <h2>Local plugins work. The public registry comes later.</h2>
      <p class="plugins-lede">
        Nagi keeps the inherited local plugin engine, but it does not claim an
        upstream marketplace or list unverified repositories as Nagi plugins.
      </p>
      <p class="plugins-trust">
        Read the <a href="/nagi/docs/plugins/">local plugin documentation</a>, or
        follow registry work on
        <a href="https://github.com/Cod-Hash-Studios/nagi/issues">GitHub</a>.
      </p>
    </section>
  </main>
</MarketingLayout>
