---
import MarketingLayout from '../components/MarketingLayout.astro';
---

<MarketingLayout
  title="Nagi in public"
  description="Follow Nagi's real public progress directly on GitHub."
  canonicalPath="/stats/"
>
  <main class="stats-page">
    <section class="section stats-hero">
      <p class="section-kicker"># built in public</p>
      <h2>Zero inherited numbers.</h2>
      <p>
        Nagi starts its own history here. Stars, issues, contributors, and
        releases are counted from the Nagi repository, never copied from its
        upstream foundation.
      </p>
      <p>
        <a class="button button-primary" href="https://github.com/Cod-Hash-Studios/nagi">
          Follow Nagi on GitHub
        </a>
      </p>
    </section>
  </main>
</MarketingLayout>
